{
  "name": "bilibili-desktop-app",
  "version": "1.0.0",
  "description": "B站鸣潮热门视频采集工具 - 桌面端",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "npm run build:renderer && electron .",
    "dev:serve": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --win",
    "pack": "npm run build:renderer && electron-builder --dir",
    "dist": "npm run build:renderer && electron-builder --win --publish=never"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.0",
    "element-plus": "^2.5.0",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^10.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.bilibili.desktop",
    "productName": "B站工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
